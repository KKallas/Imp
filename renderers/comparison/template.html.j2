<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }} — Comparison</title>
    <script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
    <style>
        :root {
            --fg: #1f2933;
            --muted: #6b7280;
            --border: #e5e7eb;
            --pos: #059669;
            --neg: #dc2626;
            --neu: #6b7280;
        }
        * { box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI",
                         Roboto, Oxygen, Ubuntu, sans-serif;
            color: var(--fg);
            margin: 0;
            padding: 24px;
            max-width: 1600px;
            margin-left: auto;
            margin-right: auto;
        }
        h1 { margin-top: 0; }
        .meta {
            color: var(--muted);
            font-size: 14px;
            margin-bottom: 24px;
        }
        .meta code {
            background: #f3f4f6;
            padding: 1px 6px;
            border-radius: 4px;
            font-size: 13px;
        }
        .pair {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 32px;
        }
        @media (max-width: 1100px) {
            .pair { grid-template-columns: 1fr; }
        }
        .panel {
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 16px;
            background: #fff;
            overflow-x: auto;
        }
        .panel h2 {
            margin-top: 0;
            font-size: 16px;
        }
        .panel .panel-meta {
            font-size: 12px;
            color: var(--muted);
            margin-bottom: 12px;
        }
        .panel.empty p {
            color: var(--muted);
            margin: 0;
        }
        .mermaid { font-size: 13px; }
        .deltas {
            margin-top: 16px;
        }
        .deltas h2 {
            font-size: 16px;
            margin-bottom: 8px;
        }
        .deltas table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }
        .deltas th, .deltas td {
            text-align: left;
            padding: 6px 10px;
            border-bottom: 1px solid var(--border);
        }
        .deltas th {
            background: #f9fafb;
            font-weight: 600;
        }
        .delta-pos { color: var(--pos); font-weight: 600; }
        .delta-neg { color: var(--neg); font-weight: 600; }
        .delta-neu { color: var(--neu); }
        .tag {
            display: inline-block;
            padding: 1px 6px;
            border-radius: 3px;
            background: #f3f4f6;
            font-size: 11px;
            color: var(--muted);
            margin-left: 4px;
        }
        footer {
            margin-top: 48px;
            padding-top: 16px;
            border-top: 1px solid var(--border);
            color: var(--muted);
            font-size: 12px;
            text-align: center;
        }
    </style>
</head>
<body>
    <h1>{{ title }}</h1>
    <p class="meta">
        <strong>{{ baseline_label }}</strong> vs
        <strong>{{ variant_label }}</strong> · Rendered
        <code>{{ rendered_at }}</code>
    </p>

    <div class="pair">
        <div class="panel{% if not baseline_mermaid %} empty{% endif %}">
            <h2>{{ baseline_label }}</h2>
            <div class="panel-meta">
                {{ baseline_count }} issues · {{ baseline_renderable }} charted
            </div>
            {% if baseline_mermaid %}
                <pre class="mermaid">
{{ baseline_mermaid }}
                </pre>
            {% else %}
                <p>No renderable issues.</p>
            {% endif %}
        </div>

        <div class="panel{% if not variant_mermaid %} empty{% endif %}">
            <h2>{{ variant_label }}</h2>
            <div class="panel-meta">
                {{ variant_count }} issues · {{ variant_renderable }} charted
            </div>
            {% if variant_mermaid %}
                <pre class="mermaid">
{{ variant_mermaid }}
                </pre>
            {% else %}
                <p>No renderable issues.</p>
            {% endif %}
        </div>
    </div>

    <div class="deltas">
        <h2>Δ per issue ({{ deltas | length }})</h2>
        {% if deltas %}
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Issue</th>
                    <th>{{ baseline_label }} end</th>
                    <th>{{ variant_label }} end</th>
                    <th>Δ days</th>
                </tr>
            </thead>
            <tbody>
                {% for d in deltas %}
                <tr>
                    <td>{{ d.number }}</td>
                    <td>
                        {{ d.title }}
                        {% if d.only_in == "baseline" %}
                            <span class="tag">only in {{ baseline_label }}</span>
                        {% elif d.only_in == "variant" %}
                            <span class="tag">only in {{ variant_label }}</span>
                        {% endif %}
                    </td>
                    <td>{{ d.baseline_end or "—" }}</td>
                    <td>{{ d.variant_end or "—" }}</td>
                    <td>
                        {% if d.delta_days is none %}
                            <span class="delta-neu">—</span>
                        {% elif d.delta_days > 0 %}
                            <span class="delta-neg">+{{ d.delta_days }}d</span>
                        {% elif d.delta_days < 0 %}
                            <span class="delta-pos">{{ d.delta_days }}d</span>
                        {% else %}
                            <span class="delta-neu">0</span>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
            <p class="meta">No overlapping issues to compare.</p>
        {% endif %}
    </div>

    <footer>
        Generated by <code>pipeline/render_chart.py --template comparison</code>
    </footer>

    <script>
        mermaid.initialize({ startOnLoad: true, theme: "default" });
    </script>
</body>
</html>
