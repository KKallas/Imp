<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }} — Gantt</title>
    <script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
    <style>
        :root {
            --fg: #1f2933;
            --muted: #6b7280;
            --border: #e5e7eb;
            --warn-bg: #fff8db;
            --warn-border: #f5c518;
            --crit: #dc2626;
        }
        * { box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI",
                         Roboto, Oxygen, Ubuntu, sans-serif;
            color: var(--fg);
            margin: 0;
            padding: 24px;
            max-width: 1400px;
            margin-left: auto;
            margin-right: auto;
        }
        h1 { margin-top: 0; }
        .meta {
            color: var(--muted);
            font-size: 14px;
            margin-bottom: 24px;
        }
        .meta code {
            background: #f3f4f6;
            padding: 1px 6px;
            border-radius: 4px;
            font-size: 13px;
        }
        .summary {
            display: flex;
            gap: 24px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }
        .summary > div {
            background: #f9fafb;
            border: 1px solid var(--border);
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 14px;
        }
        .summary strong {
            display: block;
            font-size: 22px;
            color: var(--fg);
        }
        .summary .delayed { color: var(--crit); }
        .chart-wrap {
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 20px;
            background: #fff;
            overflow-x: auto;
        }
        .mermaid {
            font-size: 13px;
        }
        .missing {
            margin-top: 32px;
            background: var(--warn-bg);
            border: 1px solid var(--warn-border);
            padding: 16px 20px;
            border-radius: 8px;
        }
        .missing h2 { margin-top: 0; font-size: 18px; }
        .missing ul {
            margin: 8px 0 0;
            padding-left: 20px;
        }
        .missing li {
            margin: 4px 0;
            font-size: 14px;
        }
        .missing .reason {
            color: var(--muted);
            font-size: 12px;
            margin-left: 6px;
        }
        footer {
            margin-top: 48px;
            padding-top: 16px;
            border-top: 1px solid var(--border);
            color: var(--muted);
            font-size: 12px;
            text-align: center;
        }
    </style>
</head>
<body>
    <h1>{{ title }}</h1>
    <p class="meta">
        Synced <code>{{ synced_at or "never" }}</code> · Enriched
        <code>{{ enriched_at or "never" }}</code> · Rendered
        <code>{{ rendered_at }}</code>
    </p>

    <div class="summary">
        <div>
            Issues<br>
            <strong>{{ issue_count }}</strong>
        </div>
        <div>
            Charted<br>
            <strong>{{ renderable_issues | length }}</strong>
        </div>
        <div>
            Without dates<br>
            <strong>{{ missing_issues | length }}</strong>
        </div>
        {% if delayed_count %}
        <div>
            Delayed<br>
            <strong class="delayed">{{ delayed_count }}</strong>
        </div>
        {% endif %}
    </div>

    {% if renderable_issues %}
    <div class="chart-wrap">
        <pre class="mermaid">
{{ mermaid_text }}
        </pre>
    </div>
    {% else %}
    <div class="chart-wrap">
        <p style="color: var(--muted); margin: 0;">
            No issues with start/end/duration combinations to chart yet.
            See the list below for what's missing.
        </p>
    </div>
    {% endif %}

    {% if missing_issues %}
    <div class="missing">
        <h2>Issues without dates ({{ missing_issues | length }})</h2>
        <p>
            These weren't drawn on the chart — they need at least two of
            <code>start_date</code>, <code>end_date</code>, or
            <code>duration_days</code>.
        </p>
        <ul>
        {% for i in missing_issues %}
            <li>
                <strong>#{{ i.number }}</strong>: {{ i.title }}
                <span class="reason">— {{ i.reason }}</span>
            </li>
        {% endfor %}
        </ul>
    </div>
    {% endif %}

    <footer>
        Generated by <code>pipeline/render_chart.py --template gantt</code>
    </footer>

    <script>
        mermaid.initialize({ startOnLoad: true, theme: "default" });
    </script>
</body>
</html>
