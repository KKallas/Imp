<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }} — Burndown</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
    <style>
        :root {
            --fg: #1f2933;
            --muted: #6b7280;
            --border: #e5e7eb;
            --warn-bg: #fff8db;
            --warn-border: #f5c518;
        }
        * { box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI",
                         Roboto, Oxygen, Ubuntu, sans-serif;
            color: var(--fg);
            margin: 0;
            padding: 24px;
            max-width: 1200px;
            margin-left: auto;
            margin-right: auto;
        }
        h1 { margin-top: 0; }
        .meta {
            color: var(--muted);
            font-size: 14px;
            margin-bottom: 24px;
        }
        .meta code {
            background: #f3f4f6;
            padding: 1px 6px;
            border-radius: 4px;
            font-size: 13px;
        }
        .summary {
            display: flex;
            gap: 24px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }
        .summary > div {
            background: #f9fafb;
            border: 1px solid var(--border);
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 14px;
        }
        .summary strong {
            display: block;
            font-size: 22px;
            color: var(--fg);
        }
        .chart-wrap {
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 20px;
            background: #fff;
        }
        .chart-wrap canvas {
            max-height: 420px;
        }
        .empty {
            color: var(--muted);
            margin: 0;
        }
        .missing {
            margin-top: 32px;
            background: var(--warn-bg);
            border: 1px solid var(--warn-border);
            padding: 16px 20px;
            border-radius: 8px;
        }
        .missing h2 { margin-top: 0; font-size: 18px; }
        .missing ul { margin: 8px 0 0; padding-left: 20px; }
        .missing li { margin: 4px 0; font-size: 14px; }
        .missing .reason {
            color: var(--muted);
            font-size: 12px;
            margin-left: 6px;
        }
        footer {
            margin-top: 48px;
            padding-top: 16px;
            border-top: 1px solid var(--border);
            color: var(--muted);
            font-size: 12px;
            text-align: center;
        }
    </style>
</head>
<body>
    <h1>{{ title }}</h1>
    <p class="meta">
        Synced <code>{{ synced_at or "never" }}</code> · Enriched
        <code>{{ enriched_at or "never" }}</code> · Rendered
        <code>{{ rendered_at }}</code>
    </p>

    <div class="summary">
        <div>Tracked<br><strong>{{ tracked_count }}</strong></div>
        <div>Open today<br><strong>{{ open_today }}</strong></div>
        <div>Total span<br><strong>{{ span_days }} days</strong></div>
        {% if excluded_count %}
        <div>Out-scoped<br><strong>{{ excluded_count }}</strong></div>
        {% endif %}
    </div>

    <div class="chart-wrap">
        {% if labels %}
            <canvas id="burndown"></canvas>
        {% else %}
            <p class="empty">
                No issues with a <code>createdAt</code> timestamp to burn
                down yet — see the list below.
            </p>
        {% endif %}
    </div>

    {% if excluded_count %}
    <p class="meta">
        {{ excluded_count }} closed
        {% if excluded_count == 1 %}issue{% else %}issues{% endif %}
        excluded as <code>NOT_PLANNED</code> (out-of-scope, not completed).
    </p>
    {% endif %}

    {% if missing_issues %}
    <div class="missing">
        <h2>Issues without timestamps ({{ missing_issues | length }})</h2>
        <p>
            These can't be placed on the burndown — they need a
            <code>createdAt</code> timestamp from <code>gh</code> or an
            explicit <code>start_date</code> field.
        </p>
        <ul>
        {% for i in missing_issues %}
            <li>
                <strong>#{{ i.number }}</strong>: {{ i.title }}
                <span class="reason">— {{ i.reason }}</span>
            </li>
        {% endfor %}
        </ul>
    </div>
    {% endif %}

    <footer>
        Generated by <code>pipeline/render_chart.py --template burndown</code>
    </footer>

    {% if labels %}
    <script>
        const ctx = document.getElementById("burndown");
        new Chart(ctx, {
            type: "line",
            data: {
                labels: {{ labels | tojson }},
                datasets: [
                    {
                        label: "Remaining (actual)",
                        data: {{ remaining | tojson }},
                        borderColor: "#2563eb",
                        backgroundColor: "rgba(37,99,235,0.1)",
                        tension: 0.15,
                        fill: true,
                    },
                    {
                        label: "Ideal",
                        data: {{ ideal | tojson }},
                        borderColor: "#9ca3af",
                        borderDash: [6, 4],
                        pointRadius: 0,
                        tension: 0,
                        fill: false,
                    }
                ]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        title: { display: true, text: "Open issues" }
                    },
                    x: { title: { display: true, text: "Date" } }
                },
                plugins: { legend: { position: "bottom" } }
            }
        });
    </script>
    {% endif %}
</body>
</html>
