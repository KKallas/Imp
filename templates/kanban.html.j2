<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }} — Kanban</title>
    <style>
        :root {
            --fg: #1f2933;
            --muted: #6b7280;
            --border: #e5e7eb;
            --open-bg: #eff6ff;
            --open-border: #bfdbfe;
            --prog-bg: #fef9c3;
            --prog-border: #fde68a;
            --done-bg: #dcfce7;
            --done-border: #bbf7d0;
            --crit: #dc2626;
        }
        * { box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI",
                         Roboto, Oxygen, Ubuntu, sans-serif;
            color: var(--fg);
            margin: 0;
            padding: 24px;
            max-width: 1400px;
            margin-left: auto;
            margin-right: auto;
        }
        h1 { margin-top: 0; }
        .meta {
            color: var(--muted);
            font-size: 14px;
            margin-bottom: 24px;
        }
        .meta code {
            background: #f3f4f6;
            padding: 1px 6px;
            border-radius: 4px;
            font-size: 13px;
        }
        .board {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
        }
        @media (max-width: 900px) {
            .board { grid-template-columns: 1fr; }
        }
        .column {
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 12px;
            min-height: 120px;
        }
        .column h2 {
            margin: 0 0 12px 0;
            font-size: 15px;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .column .count {
            font-weight: normal;
            color: var(--muted);
            font-size: 13px;
        }
        .column.open { background: var(--open-bg); border-color: var(--open-border); }
        .column.in-progress { background: var(--prog-bg); border-color: var(--prog-border); }
        .column.done { background: var(--done-bg); border-color: var(--done-border); }
        .cards {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .card {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 10px 12px;
            font-size: 13px;
            box-shadow: 0 1px 2px rgba(0,0,0,0.03);
        }
        .card .num {
            color: var(--muted);
            font-size: 12px;
            font-weight: 500;
        }
        .card .t {
            margin-top: 2px;
            line-height: 1.35;
        }
        .card .assignees {
            margin-top: 6px;
            font-size: 12px;
            color: var(--muted);
        }
        .card .assignees .none { font-style: italic; }
        .card.delayed {
            border-left: 3px solid var(--crit);
        }
        .empty {
            color: var(--muted);
            font-size: 13px;
            font-style: italic;
            padding: 8px 4px;
        }
        footer {
            margin-top: 48px;
            padding-top: 16px;
            border-top: 1px solid var(--border);
            color: var(--muted);
            font-size: 12px;
            text-align: center;
        }
    </style>
</head>
<body>
    <h1>{{ title }}</h1>
    <p class="meta">
        Synced <code>{{ synced_at or "never" }}</code> · Enriched
        <code>{{ enriched_at or "never" }}</code> · Rendered
        <code>{{ rendered_at }}</code> · {{ issue_count }} issues
    </p>

    <div class="board">
        {% for col in columns %}
        <div class="column {{ col.slug }}">
            <h2>
                {{ col.label }}
                <span class="count">{{ col.cards | length }}</span>
            </h2>
            <div class="cards">
                {% if col.cards %}
                    {% for c in col.cards %}
                    <div class="card{% if c.delayed %} delayed{% endif %}">
                        <div class="num">#{{ c.number }}</div>
                        <div class="t">{{ c.title }}</div>
                        <div class="assignees">
                            {% if c.assignees %}
                                {{ c.assignees | join(", ") }}
                            {% else %}
                                <span class="none">unassigned</span>
                            {% endif %}
                        </div>
                    </div>
                    {% endfor %}
                {% else %}
                    <div class="empty">No issues.</div>
                {% endif %}
            </div>
        </div>
        {% endfor %}
    </div>

    <footer>
        Generated by <code>pipeline/render_chart.py --template kanban</code>
    </footer>
</body>
</html>
